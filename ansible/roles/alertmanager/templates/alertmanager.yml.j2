# Alertmanager routing. Grouping/timing per contract §7. Fired alerts fan out to
# the Sentinel agent's webhook on ctrl-1:8080/alerts (private IP from inventory;
# in Phase 3 that endpoint is scripts/webhook-stub.py, in Phase 4 the agent).
route:
  group_by: ["alertname", "service"]
  group_wait: 15s
  group_interval: 5m
  repeat_interval: 4h
  receiver: "sentinel-agent"

receivers:
  - name: "sentinel-agent"
    webhook_configs:
      # send_resolved so the agent also learns when an alert clears (§7: recorded,
      # but recovery is confirmed by the agent's own re-query, not trusted here).
      - url: "http://{{ hostvars['ctrl-1'].private_ip }}:8080/alerts"
        send_resolved: true
