# promtail — ships container logs to Loki on mon-1. Managed by Ansible.
server:
  http_listen_port: 9080
  grpc_listen_port: 0

positions:
  filename: /tmp/positions.yaml

clients:
  - url: http://{{ mon_ip }}:3100/loki/api/v1/push

scrape_configs:
  - job_name: docker
    docker_sd_configs:
      - host: unix:///var/run/docker.sock
        refresh_interval: 15s
    relabel_configs:
      # Ship only our containers (named sentinel-*).
      - source_labels: ["__meta_docker_container_name"]
        regex: "/sentinel-.*"
        action: keep
      # service = the bit after "sentinel-"; keep the full name too.
      - source_labels: ["__meta_docker_container_name"]
        regex: "/(sentinel-.*)"
        target_label: container
        replacement: "$1"
      - source_labels: ["__meta_docker_container_name"]
        regex: "/sentinel-(.*)"
        target_label: service
        replacement: "$1"
      - target_label: host
        replacement: "{{ inventory_hostname }}"
    pipeline_stages:
      # App lines are JSON ({"level","trace_id",...}); pull out level + trace_id.
      - json:
          expressions:
            level: level
            trace_id: trace_id
      # level is low-cardinality -> a real label; trace_id is high-cardinality ->
      # structured metadata (queryable, but not a stream label).
      - labels:
          level:
      - structured_metadata:
          trace_id:
