# Prometheus scrape config — GENERATED by Ansible from the Terraform inventory.
# Do not edit on the host; change the prometheus role instead.
global:
  scrape_interval: 15s
  evaluation_interval: 15s

alerting:
  alertmanagers:
    - static_configs:
        - targets: ["localhost:9093"]

# Alert rules arrive in Phase 3.
rule_files: []

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets: ["localhost:9090"]

  - job_name: node
    static_configs:
      - targets:
{% for h in groups['all'] | sort %}
          - "{{ hostvars[h].private_ip }}:9100"
{% endfor %}

  - job_name: cadvisor
    static_configs:
      - targets:
{% for h in (groups['app'] + groups['db']) | sort %}
          - "{{ hostvars[h].private_ip }}:8081"
{% endfor %}

  - job_name: postgres
    static_configs:
      - targets:
{% for h in groups['db'] | sort %}
          - "{{ hostvars[h].private_ip }}:9187"
{% endfor %}

  - job_name: services
    metrics_path: /metrics
    static_configs:
{% for t in app_service_targets %}
      - targets: ["{{ hostvars[t.host].private_ip }}:{{ t.port }}"]
        labels:
          service: "{{ t.service }}"
{% endfor %}

  # Phase 4: the Sentinel agent exposes /metrics on ctrl-1:8080. Uncomment once
  # the agent is deployed — until then it would be a permanently-down target.
  # - job_name: agent
  #   static_configs:
  #     - targets: ["{{ hostvars['ctrl-1'].private_ip }}:8080"]
